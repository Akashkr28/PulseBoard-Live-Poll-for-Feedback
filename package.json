{
  "name": "pulseboard-live-polls",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack live polling and feedback platform.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "test": "npm run test --workspace server",
    "lint": "npm run lint --workspace client",
    "install:all": "npm install --workspaces"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
